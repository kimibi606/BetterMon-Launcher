{
  "name": "bettermon-launcher",
  "version": "0.3.8",
  "description": "Custom Minecraft launcher built with Electron, JS and CSS.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check src/renderer.js && node --check vendor/request/index.js && node scripts/validate-release.js",
    "dist": "electron-builder build",
    "dist:win": "electron-builder build --win nsis",
    "dist:dir": "electron-builder build --dir",
    "release:github": "npm run check && npm run dist:dir && node scripts/write-app-update-config.js && electron-builder build --prepackaged dist/win-unpacked --win nsis --publish always"
  },
  "keywords": [
    "minecraft",
    "launcher",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.9",
    "minecraft-launcher-core": "^3.18.2",
    "request": "file:vendor/request"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "overrides": {
    "minecraft-launcher-core": {
      "request": "$request",
      "uuid": "^11.1.1"
    }
  },
  "build": {
    "appId": "com.bettermon.launcher",
    "productName": "BetterMon Launcher",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "vendor/request/**/*",
      "package.json",
      "modpack.config.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "src/assets/app-icon.ico",
      "signExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/app-icon.ico",
      "uninstallerIcon": "src/assets/app-icon.ico",
      "installerHeaderIcon": "src/assets/app-icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kimibi606",
        "repo": "BetterMon-Launcher",
        "releaseType": "release"
      }
    ]
  }
}
